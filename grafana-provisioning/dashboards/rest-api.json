{
  "title": "Simlab - REST API",
  "uid": "simlab-rest-api",
  "schemaVersion": 38,
  "refresh": "15s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage %",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name=~\"/?rest_api\"}[1m])) * 100",
          "legendFormat": "rest_api",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0 } }
    },
    {
      "id": 2,
      "title": "Memory Usage",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{name=~\"/?rest_api\"}",
          "legendFormat": "used",
          "refId": "A"
        },
        {
          "expr": "container_spec_memory_limit_bytes{name=~\"/?rest_api\"}",
          "legendFormat": "limit",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "min": 0 } }
    },
    {
      "id": 3,
      "title": "Network Receive (bytes/s)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(container_network_receive_bytes_total{name=~\"/?rest_api\"}[1m])",
          "legendFormat": "rx",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps", "min": 0 } }
    },
    {
      "id": 4,
      "title": "Network Transmit (bytes/s)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(container_network_transmit_bytes_total{name=~\"/?rest_api\"}[1m])",
          "legendFormat": "tx",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps", "min": 0 } }
    },
    {
      "id": 5,
      "title": "Open File Descriptors",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "container_file_descriptors{name=~\"/?rest_api\"}",
          "legendFormat": "fds",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 } }
    },
    {
      "id": 6,
      "title": "Process Count",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "container_processes{name=~\"/?rest_api\"}",
          "legendFormat": "processes",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 } }
    }
  ]
}
