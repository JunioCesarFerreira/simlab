{
  "title": "Simlab - MO Engine",
  "uid": "simlab-mo-engine",
  "schemaVersion": 38,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage %",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{name=~\"/?mo_engine\"}[1m]) * 100",
          "legendFormat": "mo_engine",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0 } }
    },
    {
      "id": 2,
      "title": "Memory Usage",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{name=~\"/?mo_engine\"}",
          "legendFormat": "used",
          "refId": "A"
        },
        {
          "expr": "container_spec_memory_limit_bytes{name=~\"/?mo_engine\"}",
          "legendFormat": "limit",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "min": 0 } }
    },
    {
      "id": 3,
      "title": "CPU % - MO Engine vs Cooja Workers",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{name=~\"/?mo_engine|/?cooja.*\"}[1m]) * 100",
          "legendFormat": "{{ name }}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0 } }
    },
    {
      "id": 4,
      "title": "Network Receive (bytes/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(container_network_receive_bytes_total{name=~\"/?mo_engine\"}[1m])",
          "legendFormat": "rx",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps", "min": 0 } }
    },
    {
      "id": 5,
      "title": "Network Transmit (bytes/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(container_network_transmit_bytes_total{name=~\"/?mo_engine\"}[1m])",
          "legendFormat": "tx",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps", "min": 0 } }
    }
  ]
}
