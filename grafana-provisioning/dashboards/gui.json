{
  "title": "Simlab - GUI",
  "uid": "simlab-gui",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage %",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name=~\"/?simlab_gui\"}[1m])) * 100",
          "legendFormat": "simlab_gui",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0 } }
    },
    {
      "id": 2,
      "title": "Memory Usage",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{name=~\"/?simlab_gui\"}",
          "legendFormat": "used",
          "refId": "A"
        },
        {
          "expr": "container_spec_memory_limit_bytes{name=~\"/?simlab_gui\"}",
          "legendFormat": "limit",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "min": 0 } }
    },
    {
      "id": 3,
      "title": "Network Receive (bytes/s)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(container_network_receive_bytes_total{name=~\"/?simlab_gui\"}[1m])",
          "legendFormat": "rx",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps", "min": 0 } }
    },
    {
      "id": 4,
      "title": "Network Transmit (bytes/s)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(container_network_transmit_bytes_total{name=~\"/?simlab_gui\"}[1m])",
          "legendFormat": "tx",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps", "min": 0 } }
    }
  ]
}
